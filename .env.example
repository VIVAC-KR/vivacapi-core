# =============================================================================
# VIVAC API 환경 변수 설정 가이드
#
# 로컬 개발:
#   cp .env.example .env.local  →  값 채우기
#
# 프로덕션 (Lightsail 인스턴스):
#   cp .env.example .env.production  →  값 채우기 (chmod 600)
#   prod에서는 placeholder/예시값을 그대로 두면 부팅이 실패한다 (config.py 검증).
# =============================================================================

# ---------------------------------------------------------------------------
# 애플리케이션 환경
# local : 서버 로컬 실행 + DB docker-compose
# dev   : 서버/DB 모두 AWS VPC 내부 직접 접속
# prod  : 서버/DB 모두 AWS VPC 내부 직접 접속 (Lightsail Instance + Managed DB)
# ---------------------------------------------------------------------------
ENVIRONMENT=local

# ---------------------------------------------------------------------------
# 데이터베이스 접속 정보
# local → docker-compose DB (DB_HOST=localhost)
# dev   → RDS / Lightsail DB 프라이빗 엔드포인트
# prod  → Lightsail Managed DB 프라이빗 엔드포인트
#         (예: ls-xxxxx.xxxxx.ap-northeast-2.rds.amazonaws.com)
# prod에서 DB_HOST=localhost 인 경우 부팅 실패
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vivac
DB_USER=vivac
DB_PASSWORD=your_db_password_here

# ---------------------------------------------------------------------------
# Google OAuth 2.0
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
# prod에서는 별도의 프로덕션 OAuth 클라이언트를 사용할 것
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# vivac-console(어드민) 로그인 시 허용할 이메일 도메인.
# 비워두면 도메인 제한 없음.
# 예) ALLOWED_EMAIL_DOMAIN=vivac.kr
ALLOWED_EMAIL_DOMAIN=

# ---------------------------------------------------------------------------
# JWT
# JWT_SECRET_KEY: 최소 32바이트 이상의 랜덤 문자열
#   생성 예시: python -c "import secrets; print(secrets.token_urlsafe(64))"
#   prod에서는 로컬/dev와 다른 고유한 값을 사용할 것
#   prod에서 placeholder("CHANGE_ME...")가 그대로 들어 있으면 부팅 실패
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ADMIN_ACCESS_TOKEN_EXPIRE_HOURS=8

# ---------------------------------------------------------------------------
# SQLAdmin (/admin) 세션
# SessionMiddleware 서명/암호화 키. JWT와는 별도의 랜덤 값을 사용한다.
#   생성 예시: python -c "import secrets; print(secrets.token_urlsafe(64))"
#   prod에서 placeholder("CHANGE_ME...")가 그대로 들어 있으면 부팅 실패
# ---------------------------------------------------------------------------
ADMIN_SESSION_SECRET=PEKiOjKgTvkkyLwRwYs69wwok3C+fMoxm8Cknifx4wI=

# ---------------------------------------------------------------------------
# CORS
# 콤마 구분 origin 리스트. 미설정 시:
#   local → http://localhost:3000, http://127.0.0.1:3000 디폴트
#   dev/prod → 빈 값 (모든 cross-origin 차단)
# prod에서는 '*' 및 localhost/127.0.0.1 포함 시 부팅 실패.
# 예) CORS_ALLOWED_ORIGINS=https://vivac.app,https://app.vivac.app
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
